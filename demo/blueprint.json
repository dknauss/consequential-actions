{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Consequential Actions",
    "author": "dknauss",
    "description": "The same reauth challenge guards every account-takeover action — change your password, create a user, or promote one to Administrator — each demands a fresh password confirmation before it commits. WP Mail Logging shows the emails those actions send."
  },
  "landingPage": "/wp-admin/profile.php",
  "preferredVersions": { "php": "8.3", "wp": "latest" },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://wordpress-playground-cors-proxy.net/?https://github.com/dknauss/consequential-actions/archive/refs/tags/v0.1.5.zip"
      },
      "options": { "activate": true, "targetFolderName": "consequential-actions" },
      "ifAlreadyInstalled": "overwrite",
      "progress": { "weight": 2, "caption": "Installing Consequential Actions" }
    },
    {
      "step": "installPlugin",
      "pluginData": { "resource": "wordpress.org/plugins", "slug": "wp-mail-logging" },
      "options": { "activate": true },
      "ifAlreadyInstalled": "overwrite",
      "progress": { "weight": 2, "caption": "Installing WP Mail Logging" }
    },
    {
      "step": "wp-cli",
      "command": "wp user create targetuser target@example.test --role=subscriber --user_pass=targetpass --display_name='Target User'"
    },
    {
      "step": "writeFile",
      "path": "/wordpress/wp-content/mu-plugins/ca-narrator.php",
      "data": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/dknauss/consequential-actions/v0.1.5/demo/mu-narrator.php"
      }
    }
  ]
}
